{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "debugpy",
      "name": "Debug AI-Exam Python Backend",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "program": "${workspaceFolder}/backend/run.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/backend/.env",
      "preLaunchTask": "pip-install"
    },
    {
      "type": "node",
      "name": "Debug AI-Exam Frontend",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
